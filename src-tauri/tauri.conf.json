{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Easy Launcher",
  "version": "0.1.0",
  "identifier": "com.easylauncher.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Easy Launcher",
        "width": 728,
        "height": 248,
        "minWidth": 520,
        "minHeight": 120,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/EasyLauncher/icons/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "useLocalToolsDir": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
